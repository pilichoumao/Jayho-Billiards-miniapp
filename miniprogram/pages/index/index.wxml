<view class="page-shell">
  <view class="hero-card">
    <text class="eyebrow">Jayho Billiards MVP</text>
    <text class="hero-title">Shot Solver</text>
    <text class="hero-copy">Switch between a contact-path search and a cue-direction trajectory, then run the local geometry solver.</text>
  </view>

  <view class="table-stage">
    <view class="table-stage__frame">
      <view class="table-stage__surface"></view>
      <view id="table-stage" class="table-stage__playfield">
        <view class="table-stage__overlay">
          <view
            wx:for="{{tablePocketAnchors}}"
            wx:key="id"
            class="pocket pocket--{{item.id}}"
            style="left: {{item.point.x * 100}}%; top: {{item.point.y * 100}}%;"
          ></view>

          <view wx:if="{{solveRenderModel}}" class="route-layer">
            <view
              wx:for="{{solveRenderModel.routeSegments}}"
              wx:key="id"
              class="route-line route-line--{{item.kind}}"
              style="left: {{item.left}}; top: {{item.top}}; width: {{item.width}}; transform: rotate({{item.angleDeg}}deg);"
            ></view>
            <view
              wx:if="{{mode === 'mode2_cue_direction' && solveRenderModel.routeArrow}}"
              class="route-arrow"
              style="left: {{solveRenderModel.routeArrow.left}}; top: {{solveRenderModel.routeArrow.top}}; transform: rotate({{solveRenderModel.routeArrow.angleDeg}}deg);"
            ></view>
            <view
              wx:for="{{solveRenderModel.markers}}"
              wx:key="id"
              class="route-point route-point--{{item.kind}}"
              style="left: {{item.point.x * 100}}%; top: {{item.point.y * 100}}%;"
            ></view>
          </view>
        </view>
        <block wx:if="{{mode === 'mode1_contact_paths'}}">
          <view
            wx:for="{{editBalls}}"
            wx:key="id"
            class="ball ball--{{item.role}}"
            style="left: {{item.pos.x * 100}}%; top: {{item.pos.y * 100}}%;"
            data-ball-id="{{item.id}}"
            bindtouchstart="handleBallDragStart"
            catchtouchmove="handleBallDragMove"
            bindtouchend="handleBallDragEnd"
          ></view>
        </block>
        <block wx:else>
          <view
            wx:if="{{cueDirectionGuide}}"
            class="cue-direction-guide"
            style="left: {{cueDirectionGuide.left}}; top: {{cueDirectionGuide.top}}; width: {{cueDirectionGuide.width}}; transform: rotate({{cueDirectionGuide.angleDeg}}deg);"
          ></view>
          <view
            wx:if="{{cueDirectionGuide}}"
            class="cue-direction-handle"
            style="left: {{cueDirectionGuide.handleLeft}}; top: {{cueDirectionGuide.handleTop}};"
            bindtouchstart="handleCueDirectionDragStart"
            catchtouchmove="handleCueDirectionDragMove"
            bindtouchend="handleCueDirectionDragEnd"
          ></view>
          <view
            wx:for="{{editBalls}}"
            wx:if="{{item.role === 'cue'}}"
            wx:key="id"
            class="ball ball--{{item.role}}"
            style="left: {{item.pos.x * 100}}%; top: {{item.pos.y * 100}}%;"
            data-ball-id="{{item.id}}"
            bindtouchstart="handleBallDragStart"
            catchtouchmove="handleBallDragMove"
            bindtouchend="handleBallDragEnd"
          ></view>
        </block>
      </view>
  </view>
  </view>

  <view wx:if="{{solveRenderModel && solveRenderModel.response.candidates.length}}" class="candidate-strip candidate-strip--table">
    <button
      wx:for="{{solveRenderModel.response.candidates}}"
      wx:key="id"
      class="candidate-chip {{selectedCandidateId === item.id ? 'is-active' : ''}}"
      data-candidate-id="{{item.id}}"
      bindtap="handleCandidateSelect"
    >
      {{item.id}}
    </button>
  </view>

  <view class="panel">
    <text class="panel-title">Mode</text>
    <radio-group class="mode-list" bindchange="handleModeChange">
      <label class="mode-item {{mode === 'mode1_contact_paths' ? 'is-active' : ''}}">
        <radio value="mode1_contact_paths" checked="{{mode === 'mode1_contact_paths'}}" color="#0f766e" />
        <view class="mode-copy">
          <text class="mode-name">Mode 1</text>
          <text class="mode-desc">Search contact paths with 2 to 5 cushions.</text>
        </view>
      </label>
      <label class="mode-item {{mode === 'mode2_cue_direction' ? 'is-active' : ''}}">
        <radio value="mode2_cue_direction" checked="{{mode === 'mode2_cue_direction'}}" color="#0f766e" />
        <view class="mode-copy">
          <text class="mode-name">Mode 2</text>
          <text class="mode-desc">Simulate a cue direction until contact, threshold, or timeout.</text>
        </view>
      </label>
    </radio-group>

    <button class="calculate-button" bindtap="handleCalculate">Calculate</button>
  </view>

  <view class="panel">
    <text class="panel-title">Result</text>
    <text wx:if="{{errorText}}" class="error-text">{{errorText}}</text>

    <view wx:if="{{!errorText && resultLines.length}}" class="result-stack">
      <text class="result-title">{{resultTitle}}</text>
      <text wx:for="{{resultLines}}" wx:key="*this" class="result-line">{{item}}</text>
    </view>

    <text wx:if="{{!errorText && !resultLines.length}}" class="placeholder-text">Choose a mode and tap calculate to inspect the first candidate.</text>
  </view>
</view>
