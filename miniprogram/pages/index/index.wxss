page {
  background: linear-gradient(180deg, #f7f3ea 0%, #efe2cf 100%);
  color: #1f2933;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero-card,
.panel {
  background: rgba(255, 252, 245, 0.92);
  border: 2rpx solid rgba(92, 72, 48, 0.14);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(84, 63, 34, 0.08);
}

.hero-card {
  padding: 36rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, rgba(255, 247, 230, 0.98), rgba(236, 247, 241, 0.96));
}

.table-stage {
  margin-bottom: 24rpx;
}

.table-stage__frame {
  position: relative;
  width: 100%;
  aspect-ratio: 2 / 1;
  border-radius: 30rpx;
  overflow: hidden;
  border: 2rpx solid rgba(50, 37, 22, 0.18);
  box-shadow: 0 18rpx 40rpx rgba(84, 63, 34, 0.08);
  background: linear-gradient(180deg, #205c3c 0%, #16412c 100%);
}

.table-stage__surface {
  position: absolute;
  inset: 20rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.08), transparent 55%),
    linear-gradient(180deg, #2f8a54 0%, #1e633d 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.table-stage__playfield {
  position: absolute;
  inset: 20rpx;
}

.table-stage__overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.route-layer {
  position: absolute;
  inset: 0;
}

.pocket {
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  margin-left: -16rpx;
  margin-top: -16rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #0f172a 0%, #030712 70%, #000 100%);
  box-shadow:
    inset 0 0 0 4rpx rgba(255, 255, 255, 0.04),
    0 6rpx 12rpx rgba(0, 0, 0, 0.28);
}

.route-line {
  position: absolute;
  height: 8rpx;
  margin-top: -4rpx;
  border-radius: 999rpx;
  transform-origin: 0 50%;
  box-shadow: 0 0 14rpx rgba(255, 255, 255, 0.14);
}

.route-line--start {
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.9), rgba(209, 250, 229, 0.9));
}

.route-line--cushion {
  background: linear-gradient(90deg, rgba(245, 158, 11, 0.95), rgba(251, 191, 36, 0.9));
}

.route-line--contact {
  background: linear-gradient(90deg, rgba(244, 63, 94, 0.95), rgba(251, 113, 133, 0.9));
}

.route-line--end {
  background: linear-gradient(90deg, rgba(56, 189, 248, 0.95), rgba(125, 211, 252, 0.9));
}

.route-arrow {
  position: absolute;
  width: 0;
  height: 0;
  margin-left: -2rpx;
  margin-top: -11rpx;
  border-top: 11rpx solid transparent;
  border-bottom: 11rpx solid transparent;
  border-left: 18rpx solid rgba(248, 250, 252, 0.95);
  filter: drop-shadow(0 0 10rpx rgba(15, 118, 110, 0.25));
  transform-origin: 0 50%;
}

.cue-direction-guide {
  position: absolute;
  height: 6rpx;
  margin-top: -3rpx;
  border-radius: 999rpx;
  transform-origin: 0 50%;
  background: linear-gradient(90deg, rgba(14, 116, 144, 0.95), rgba(56, 189, 248, 0.95));
  box-shadow: 0 0 10rpx rgba(14, 116, 144, 0.25);
  z-index: 2;
}

.cue-direction-handle {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  margin-left: -14rpx;
  margin-top: -14rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #e0f2fe 0%, #38bdf8 52%, #0369a1 100%);
  box-shadow:
    0 0 0 4rpx rgba(56, 189, 248, 0.2),
    0 8rpx 16rpx rgba(2, 132, 199, 0.28);
  z-index: 4;
}

.ball {
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  margin-left: -22rpx;
  margin-top: -22rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.24);
}

.ball--cue {
  background: radial-gradient(circle at 35% 35%, #ffffff 0%, #e8f0ef 52%, #cfd9d7 100%);
}

.ball--target {
  background: radial-gradient(circle at 35% 35%, #fff7cd 0%, #f3c94b 52%, #b2780d 100%);
}

.ball--obstacle {
  background: radial-gradient(circle at 35% 35%, #ffe7e7 0%, #d95a50 52%, #8a201b 100%);
}

.route-point {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  margin-left: -7rpx;
  margin-top: -7rpx;
  border-radius: 50%;
}

.route-point--path {
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.12);
}

.route-point--cushion {
  background: #f59e0b;
  box-shadow: 0 0 0 4rpx rgba(245, 158, 11, 0.18);
}

.route-point--contact {
  background: #f43f5e;
  box-shadow: 0 0 0 4rpx rgba(244, 63, 94, 0.18);
}

.route-point--end {
  background: #38bdf8;
  box-shadow: 0 0 0 4rpx rgba(56, 189, 248, 0.18);
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  text-transform: uppercase;
  letter-spacing: 6rpx;
  color: #0f766e;
  margin-bottom: 12rpx;
}

.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #4a3321;
}

.hero-copy {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #5b6470;
}

.panel {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.panel-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #3c2f21;
  margin-bottom: 20rpx;
}

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mode-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f7efe1;
  border: 2rpx solid transparent;
}

.mode-item.is-active {
  border-color: #0f766e;
  background: #edf9f5;
}

.mode-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.mode-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f3a45;
}

.mode-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: #5f6b76;
}

.calculate-button {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0f766e, #155e75);
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 700;
}

.result-stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3c2f21;
}

.result-line,
.placeholder-text,
.error-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
}

.result-line,
.placeholder-text {
  color: #52606d;
}

.error-text {
  color: #b42318;
}

.candidate-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.candidate-strip--table {
  margin-top: -8rpx;
  margin-bottom: 24rpx;
}

.candidate-chip {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #f7efe1;
  color: #4a5568;
  font-size: 24rpx;
  line-height: 1;
}

.candidate-chip.is-active {
  background: #0f766e;
  color: #f8fafc;
}
