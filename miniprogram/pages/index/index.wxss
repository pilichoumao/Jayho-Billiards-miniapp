page {
  background: linear-gradient(180deg, #f7f3ea 0%, #efe2cf 100%);
  color: #1f2933;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero-card,
.panel {
  background: rgba(255, 252, 245, 0.92);
  border: 2rpx solid rgba(92, 72, 48, 0.14);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(84, 63, 34, 0.08);
}

.hero-card {
  padding: 36rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, rgba(255, 247, 230, 0.98), rgba(236, 247, 241, 0.96));
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  text-transform: uppercase;
  letter-spacing: 6rpx;
  color: #0f766e;
  margin-bottom: 12rpx;
}

.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #4a3321;
}

.hero-copy {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #5b6470;
}

.panel {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.panel-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #3c2f21;
  margin-bottom: 20rpx;
}

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mode-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f7efe1;
  border: 2rpx solid transparent;
}

.mode-item.is-active {
  border-color: #0f766e;
  background: #edf9f5;
}

.mode-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.mode-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f3a45;
}

.mode-desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: #5f6b76;
}

.calculate-button {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0f766e, #155e75);
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 700;
}

.result-stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3c2f21;
}

.result-line,
.placeholder-text,
.error-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
}

.result-line,
.placeholder-text {
  color: #52606d;
}

.error-text {
  color: #b42318;
}
